{"row_type": "component_rule", "component": "LIQUIDITY_DEPTH_RISK", "max_points": 25, "logic": ["liquidity_usd < 1000 => 25", "liquidity_usd < 3000 => 18", "liquidity_usd < 10000 => 10", "else => 0"]}
