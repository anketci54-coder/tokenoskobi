{"row_type": "component_rule", "component": "SLIPPAGE_REQUIRED_RISK", "max_points": 15, "logic": ["slippage_required_pct >= 5.0 => 15", "slippage_required_pct >= 3.0 => 10", "slippage_required_pct >= 1.5 => 5", "else => 0"]}
{"row_type": "component_rule", "component": "TX_BURST_RISK", "max_points": 10, "logic": ["tx_burst_1m >= 30 => 10", "tx_burst_1m >= 15 => 6", "tx_burst_1m >= 6 => 3", "else => 0"]}
{"row_type": "component_rule", "component": "BUY_SELL_IMBALANCE_RISK", "max_points": 8, "logic": ["abs(buy_sell_imbalance) >= 0.80 => 8", "abs(buy_sell_imbalance) >= 0.55 => 5", "abs(buy_sell_imbalance) >= 0.30 => 2", "else => 0"]}
{"row_type": "component_rule", "component": "POOL_AGE_RISK", "max_points": 8, "logic": ["pool_age_minutes < 10 => 8", "pool_age_minutes < 60 => 5", "pool_age_minutes < 240 => 2", "else => 0"]}
{"row_type": "component_rule", "component": "BOT_PATTERN_BONUS_RISK", "max_points": 12, "logic": ["same_window_swap_cluster high => +6", "known_bot_wallet_touch true => +6", "gas_spike_ratio high => +3 capped by max"]}
