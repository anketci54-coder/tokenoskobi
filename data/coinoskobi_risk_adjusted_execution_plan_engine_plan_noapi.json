  "entry_modes": [
    {
      "entry_mode": "WATCH_ONLY",
      "when": "data unknown, confidence low, opportunity not confirmed",
      "entry_amount_policy": "0",
      "tp_policy": "none",
      "button_policy": "watchlist only"
    },
    {
      "entry_mode": "NORMAL",
      "when": "risk LOW/MEDIUM, contract/sellability OK, liquidity sufficient, no hard block",
      "entry_amount_policy": "risk adjusted micro amount",
      "tp_policy": "TP1_TP2_TP3",
      "button_policy": "paper/manual allowed, auto locked"
    },
    {
      "entry_mode": "VUR_KAC",
      "when": "momentum high, volume burst, sellability OK, MEV not high, quick exit suitable",
      "entry_amount_policy": "smaller micro scalp amount",
      "tp_policy": "SINGLE_TP_ONLY",
      "button_policy": "vur-kac paper/manual allowed, auto locked"
    },
    {
      "entry_mode": "PAPER_ONLY",
      "when": "risk HIGH but not critical, future protected route required, live not allowed",
      "entry_amount_policy": "paper only simulated amount",
      "tp_policy": "depends on normal/vur-kac classification",
      "button_policy": "paper only"
    },
    {
      "entry_mode": "BLOCKED",
      "when": "critical risk, hard block, source conflict, sellability fail, live/paper lock",
      "entry_amount_policy": "0",
      "tp_policy": "none",
      "button_policy": "disabled / morg-autopsy"
    }
  ],
  "sizing_policy": [
    {
      "policy_key": "micro_base_capital",
      "formula": "base_capital_usd = min(user_micro_cap, liquidity_usd * 0.0025)",
      "purpose": "Sığ sularda küçük giriş.",
      "default_example": "10-25 USD micro start"
    },
    {
      "policy_key": "risk_multiplier",
      "formula": "LOW=1.0, MEDIUM=0.35, HIGH=0.10 paper-only, CRITICAL=0",
      "purpose": "Risk seviyesi arttıkça miktar düşer.",
      "default_example": "MEDIUM riskte 25 USD -> 8.75 USD"
    },
    {
      "policy_key": "mev_multiplier",
      "formula": "ALLOW=1.0, REDUCE_SIZE=0.25, PAPER_ONLY=0.0 live, BLOCK=0",
      "purpose": "MEV kapısı pozisyonu sınırlar.",
      "default_example": "REDUCE_SIZE ile giriş çeyreğe iner"
    },
    {
      "policy_key": "wallet_news_penalty",
      "formula": "wallet_risk_high or negative_news => extra 0.25-0.60 multiplier",
      "purpose": "Cüzdan/haber riskinde küçük giriş veya blok.",
      "default_example": "riskli deployer -> pozisyon küçülür"
    },
    {
      "policy_key": "liquidity_exit_cap",
      "formula": "entry_amount_usd <= liquidity_usd * max_pool_share_pct",
      "purpose": "Çıkış yapılamayacak büyüklüğü engeller.",
      "default_example": "poolun çok küçük yüzdesi"
    }
  ],
  "entry_level_policy": [
    {
      "policy_key": "technical_entry_zone_first",
      "rule": "Teknik merkez entry zone verirse entry_level bu bölgede seçilir.",
      "fallback": "current_price with price impact guard"
    },
    {
      "policy_key": "late_entry_guard",
      "rule": "momentum çok ilerlediyse ve entry supporttan uzaksa WATCH_ONLY veya VUR_KAC_SMALL",
      "fallback": "no chase"
    },
    {
      "policy_key": "risk_adjusted_entry_level",
      "rule": "risk MEDIUM/HIGH ise entry level daha konservatif seçilir.",
      "fallback": "wait better entry"
    }
  ],
  "slippage_policy": [
    {
      "policy_key": "auto_slippage_low",
      "condition": "LOW risk, low impact",
      "range": "0.15%-0.40%",
      "effect": "normal micro route"
    },
    {
      "policy_key": "auto_slippage_medium",
      "condition": "MEDIUM risk or MEV REDUCE_SIZE",
      "range": "0.40%-0.90%",
      "effect": "dynamic cap required"
    },
    {
      "policy_key": "auto_slippage_high",
      "condition": "HIGH risk",
      "range": "no live public route",
      "effect": "paper/protected route only"
    },
    {
      "policy_key": "auto_slippage_critical",
      "condition": "CRITICAL or hard block",
      "range": "none",
      "effect": "entry blocked"
    }
  ],
  "tp_sl_policy": [
    {
      "mode": "NORMAL",
      "tp_policy": "TP1_TP2_TP3",
      "required_outputs": [
        "entry_level",
        "sl_price",
        "tp1_price",
        "tp2_price",
        "tp3_price"
