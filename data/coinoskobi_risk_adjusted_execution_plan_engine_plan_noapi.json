      "default_logic": "TP1 yakın kâr, TP2 orta, TP3 koşarsa bırak; SL teknik/risk tabanlı.",
      "forbidden_outputs": []
    },
    {
      "mode": "VUR_KAC",
      "tp_policy": "SINGLE_TP_ONLY",
      "required_outputs": [
