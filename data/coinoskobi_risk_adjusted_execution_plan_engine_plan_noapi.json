        "sl_price_or_trailing_policy",
        "single_tp_price"
      ],
      "default_logic": "Tek hedef; vur-kaçta TP1/TP2/TP3 yok.",
      "forbidden_outputs": [
        "tp1_price",
        "tp2_price",
        "tp3_price"
      ]
    },
    {
      "mode": "BLOCKED",
      "tp_policy": "NONE",
      "required_outputs": [
        "blocked_reason"
      ],
      "default_logic": "İşlem yok.",
