  "financial_formulas": [
    {
      "name": "gross_reward_to_tp1_usd",
      "formula": "position_size_usd * ((tp1_price - entry_price) / entry_price)"
    },
    {
      "name": "gross_loss_to_sl_usd",
      "formula": "position_size_usd * ((entry_price - sl_price) / entry_price)"
    },
    {
      "name": "total_cost_usd",
      "formula": "gas_cost_usd + slippage_cost_usd + mev_cost_usd + buy_tax_usd + sell_tax_usd"
    },
    {
      "name": "expected_net_value_usd",
      "formula": "(tp_probability * expected_reward_usd) - (sl_probability * expected_loss_usd) - total_cost_usd"
    },
    {
      "name": "risk_reward_ratio",
      "formula": "expected_net_reward_usd / max_loss_usd"
    },
    {
      "name": "liquidity_adjusted_max_buy_usd",
      "formula": "liquidity_usd * liquidity_percent_limit"
    },
    {
      "name": "risk_adjusted_multiplier",
      "formula": "max(min_multiplier, 1 - normalized_risk_score)"
    },
    {
      "name": "risk_adjusted_position_size_usd",
      "formula": "base_position_size_usd * risk_adjusted_multiplier * confidence_multiplier"
    },
    {
      "name": "final_safe_buy_usd",
      "formula": "min(fixed_limit, capital_percent_limit, daily_remaining, chain_remaining, liquidity_adjusted_max_buy, risk_adjusted_position_size)"
    },
    {
      "name": "max_loss_pct_of_capital",
      "formula": "max_loss_usd / capital_base_usd"
    }
  ],
