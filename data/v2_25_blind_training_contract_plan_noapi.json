{
  "schema_name": "v2_25_blind_training_contract_plan_noapi",
  "version": "V2_25",
  "outcome_leakage_forbidden": true,
  "model_must_score_before_outcome": true,
  "outcome_revealed_after_decision": true,
  "reasoning_path_audit_required": true,
  "lesson_extraction_required": true,
  "auto_learning_apply_forbidden": true,
  "human_approval_required_for_weight_change": true,
  "blind_training_flow": [
    "select historical event and timestamp",
    "build visible data window only up to event time",
    "hide outcome and post-event market result",
    "produce signal vector and candidate decision",
    "freeze blind decision and audit trace",
    "reveal outcome after decision",
    "compare prediction, reason path, and actual result",
    "extract lesson and candidate rule or weight change",
    "require human approval before any change"
  ],
  "blind_case_required_fields": [
    "case_id",
    "historical_time",
    "visible_data_until",
    "hidden_outcome_until",
    "blind_signal_vector",
    "blind_candidate_score",
    "blind_decision",
    "blind_short_reason",
    "blind_audit_json",
    "actual_outcome",
    "price_after_1h",
    "price_after_6h",
    "price_after_24h",
    "liquidity_after",
    "rug_or_not",
    "pump_or_dump_or_not",
    "decision_correct",
    "reasoning_correct",
    "false_positive",
    "false_negative",
    "missed_signal",
    "overweighted_signal",
    "underweighted_signal",
    "lesson",
    "weight_change_candidate",
    "rule_change_candidate",
    "human_approval_required"
  ],
  "speed_training_boundary": {
    "blind_historical_training_is_cold_path_only": true,
    "blind_training_must_not_block_live_hot_path": true,
    "outcome_reveal_and_reasoning_path_audit_are_async": true,
    "training_can_enrich_future_candidates_but_cannot_delay_first_reaction": true
  }
}
