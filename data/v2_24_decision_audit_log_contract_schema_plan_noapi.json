{
  "schema_name": "v2_24_decision_audit_log_contract_schema_plan_noapi",
  "version": "V2_24",
  "mode": "PLAN_ONLY_NOAPI",
  "strict": true,
  "mandatory_fields": [
    "decision_id",
    "token_uid",
    "chain",
    "contract_address",
    "decision_time",
    "decision_type",
    "final_decision",
    "final_score",
    "source_score",
    "team_score",
    "onchain_score",
    "liquidity_score",
    "whale_score",
    "simulation_score",
    "risk_penalty",
    "hard_block_triggered",
    "hard_block_reasons",
    "source_count",
    "same_origin_cluster_count",
    "independent_source_count",
    "unique_platform_count",
    "diversity_score",
    "independence_factor",
    "evidence_level",
    "echo_chamber_flag",
    "wash_trade_suspected",
    "critical_holder_concentration",
    "team_wallet_concentration",
    "vesting_or_lock",
    "vur_kac_score",
    "vur_kac_decision",
    "poligon_decision",
    "short_reason",
    "audit_json",
    "created_at"
  ],
  "nullable_fields": [],
  "constraints": {
    "NO_SCORE_WITHOUT_AUDIT_TRACE": true,
    "NO_RED_WITHOUT_REASON": true,
    "NO_HARD_BLOCK_WITHOUT_REASON": true,
    "NO_VUR_KAC_DECISION_WITHOUT_EXIT_SAFETY": true,
    "NO_POLIGON_DECISION_WITHOUT_DECISION_REASON": true,
    "AUDIT_JSON_AUDITABLE_BY_DESIGN": true,
    "FIELD_MANDATORY_VALIDATION": "enabled",
    "DECISION_AUDIT_LOG_CONTRACT_SCHEMA": "strict"
  },
  "types": {
    "decision_id": "string",
    "token_uid": "string",
    "chain": "string",
    "contract_address": "string",
    "decision_time": "iso8601_string",
    "decision_type": "string",
    "final_decision": "enum:UYGUN|POLIGONA_GONDER|IZLE|ZAYIF_BEKLE|RED",
    "final_score": "number_0_100",
    "source_score": "number_0_100",
    "team_score": "number_0_100",
    "onchain_score": "number_0_100",
    "liquidity_score": "number_0_100",
    "whale_score": "number_0_100",
    "simulation_score": "number_0_100",
    "risk_penalty": "number_0_100",
    "hard_block_triggered": "boolean",
    "hard_block_reasons": "array_string",
    "source_count": "integer",
    "same_origin_cluster_count": "integer",
    "independent_source_count": "integer",
    "unique_platform_count": "integer",
    "diversity_score": "number_0_1",
    "independence_factor": "number_0_1",
    "evidence_level": "string",
    "echo_chamber_flag": "boolean",
    "wash_trade_suspected": "boolean",
    "critical_holder_concentration": "boolean",
    "team_wallet_concentration": "number_0_1",
    "vesting_or_lock": "boolean",
    "vur_kac_score": "number_0_100",
    "vur_kac_decision": "enum:YES|NO",
    "poligon_decision": "enum:YES|NO",
    "short_reason": "string",
    "audit_json": "object",
    "created_at": "iso8601_string"
  },
  "logic_rules": [
    "if final_decision == RED then short_reason must be non-empty",
    "if hard_block_triggered == true then hard_block_reasons must be non-empty",
    "if echo_chamber_flag == true then same_origin_cluster_count and independent_source_count must exist",
    "if vur_kac_decision == YES then audit_json.exit_safety must be sufficient and net_potential must be positive",
    "if poligon_decision == YES then short_reason and audit_json must justify simulation route",
    "independence_factor must be bounded between 0.40 and 1.00 under V2_23 formula",
    "no DB scoring write may happen before V2_24 schema is post-audited and GitHub sealed"
  ]
}
