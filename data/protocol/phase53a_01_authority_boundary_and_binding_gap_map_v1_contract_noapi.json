  "mandatory_rules": [
    {
      "id": "RULE_01",
      "name": "Advisory data cannot become intent",
      "pseudo": "IF payload.type in ['trade_intent','wallet_instruction','order_payload','execution_signal'] THEN allowed=false AND classify=AUTHORITY_LEAK"
    },
    {
      "id": "RULE_02",
      "name": "Hard-Block cannot be downgraded",
      "pseudo": "IF risk_engine.hard_block == true THEN final_state=HARD_BLOCK AND downstream_override_allowed=false"
    },
    {
      "id": "RULE_03",
      "name": "AI cannot override deterministic rule",
      "pseudo": "IF ai_opinion conflicts with risk_engine.verdict THEN final_state=risk_engine.verdict"
    },
    {
      "id": "RULE_04",
      "name": "Confidence is not permission",
      "pseudo": "IF confidence_score >= threshold THEN permission_granted=false"
    },
    {
      "id": "RULE_05",
      "name": "Consumer Binding is display only",
      "pseudo": "IF consumer_output includes action_button OR execution_route THEN allowed=false AND classify=PANEL_ACTION_CONFUSION"
    },
    {
      "id": "RULE_06",
      "name": "Missing evidence cannot allow",
      "pseudo": "IF evidence_ref missing THEN route=REVIEW_OR_HARD_BLOCK AND allow=false"
    }
  ],
