      "writes_db": false,
      "writes_live_decision": false,
      "zero_copy_ref_only": true
    },
    {
      "action": "validate_flat_fixed_cmp_v1_header",
      "fail_behavior": "REJECT_WITH_REASON_CODE",
      "name": "CMP_HEADER_VALIDATE",
      "source_contract": "CMP_V1",
      "stage": 2,
      "writes_live_decision": false
    },
    {
      "action": "apply_existing_mtu_ttl_regime_context_checks",
      "evidence_body_hot_message_allowed": false,
      "fragmentation_hot_path_allowed": false,
      "name": "MTU_TTL_REGIME_VALIDATE",
      "source_contract": "CMP_V1_MTU_FRAGMENTATION_GUARD",
      "stage": 3,
      "writes_live_decision": false
    },
    {
      "action": "read_provider_reputation_source_trust_cluster_and_shadow_policy",
      "name": "TRUST_ENGINE_READ",
      "source_contract": "PROVIDER_REPUTATION_SOURCE_TRUST_V1",
      "source_independence_not_assumed": true,
      "stage": 4,
      "trust_is_contextual": true,
      "trust_read_immutable_snapshot_required": true,
      "trust_snapshot_ref_required": true,
      "writes_live_decision": false
    },
    {
      "action": "compute_allow_watch_recheck_escalate_downrank_block_permaban_shadow_only_as_would_have_action",
      "actual_hard_block_forbidden_in_plan": true,
      "binary_trust_forbidden": true,
      "name": "SPECTRAL_ROUTE_COMPUTE",
      "source_contract": "PROVIDER_REPUTATION_SOURCE_TRUST_V1",
      "stage": 5,
      "writes_live_decision": false
    },
    {
      "action": "emit_explicit_reason_code_and_trace_record_plan",
      "allow_watch_trace_summary_only": true,
      "name": "REASON_TRACE_EMIT",
      "silent_failure_forbidden": true,
      "source_contract": "PROVIDER_REPUTATION_SOURCE_TRUST_V1",
      "stage": 6,
      "trace_id_required": true,
      "trace_log_flood_guard_required": true,
      "trace_verbose_only_for_anomaly": true,
      "writes_live_decision": false
    },
    {
      "action": "create_prosecutor_evidence_request_reference_only",
      "cache_miss_cannot_create_decision": true,
      "name": "PROSECUTOR_ASYNC_REQUEST_ENQUEUE",
      "orchestrator_cannot_wait_on_prosecutor_queue_flush": true,
      "prosecutor_queue_backpressure_guard_required": true,
      "source_contract": "PROSECUTOR_EVIDENCE_REQUEST_V1",
      "stage": 7,
      "sync_blocking_forbidden": true,
      "sync_wait_for_evidence_forbidden": true,
      "writes_live_decision": false
    },
    {
      "action": "hold_decision_until_evidence_verified",
      "decision_forbidden_until_evidence_verified": true,
      "name": "WAIT_EVIDENCE_STATE",
      "source_contract": "PROSECUTOR_EVIDENCE_REQUEST_V1",
      "stage": 8,
      "writes_live_decision": false
    }
  ],
