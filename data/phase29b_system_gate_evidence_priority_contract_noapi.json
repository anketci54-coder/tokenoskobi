  "evidence_priority_contract": {
    "contract_name": "system_gate_evidence_priority_contract_v1",
    "core_rule": "System Gate decisions must be based on ordered, current, direct evidence before historical or representation evidence.",
    "priority_order": [
      {
        "rank": 1,
        "name": "DIRECT_CURRENT_EVIDENCE",
        "authority": "highest",
        "examples": [
          "current DB integrity/quick/FK result",
          "current runner SHA",
          "current active index SHA",
          "current service Result and ExecMainStatus",
          "current timer active/enabled state",
          "current forbidden action evidence"
        ],
        "can_fail": true,
        "can_accept_false_alarm": true,
        "notes": "Direct current evidence beats inferred/historical evidence."
      },
      {
        "rank": 2,
        "name": "UNIT_FILE_EVIDENCE",
        "authority": "high",
        "examples": [
          "timer unit OnBootSec=60s",
          "timer unit OnUnitActiveSec=15s",
          "timer Unit=expected service",
          "service ExecStart expected runner path"
        ],
        "can_fail": true,
        "can_accept_false_alarm": true,
        "notes": "Unit file evidence can resolve systemctl representation mismatch."
      },
      {
        "rank": 3,
        "name": "SYSTEMCTL_SHOW_CURRENT",
        "authority": "high_with_representation_guard",
        "examples": [
          "Result=success",
          "ExecMainStatus=0",
          "NeedDaemonReload=no",
          "ActiveState/SubState",
          "FragmentPath"
        ],
        "can_fail": true,
        "can_accept_false_alarm": true,
        "notes": "systemctl show is current but can have representation gaps."
      },
      {
        "rank": 4,
        "name": "DB_CURRENT_HEALTH",
        "authority": "hard_system_health",
        "examples": [
          "PRAGMA integrity_check",
          "PRAGMA quick_check",
          "PRAGMA foreign_key_check row count",
          "paper runtime count"
        ],
        "can_fail": true,
        "can_accept_false_alarm": false,
        "notes": "DB integrity/FK failure is hard failure, not a representation issue."
      },
      {
        "rank": 5,
        "name": "CURRENT_RUNTIME_OUTPUT",
        "authority": "runtime_context",
        "examples": [
          "runtime output parse OK",
          "safe downgrade bucket",
          "current output files",
          "current run manifest"
        ],
        "can_fail": true,
        "can_accept_false_alarm": true,
        "notes": "Must be tied to current run/output window."
      },
      {
        "rank": 6,
        "name": "CURRENT_JOURNAL_WINDOW",
        "authority": "current_log_context",
        "examples": [
          "journal since current LastTrigger",
          "current service run error",
          "current traceback",
          "current success block"
        ],
        "can_fail": true,
        "can_accept_false_alarm": true,
        "notes": "Only current-window logs can support current failure."
      },
      {
        "rank": 7,
        "name": "HISTORICAL_JOURNAL_CONTEXT_ONLY",
        "authority": "context_only",
        "examples": [
          "old traceback",
          "old expected review",
          "old failed validator",
          "old path mismatch"
        ],
        "can_fail": false,
        "can_accept_false_alarm": false,
        "notes": "Historical logs cannot create current FAIL without current evidence."
      }
    ],
