  "validator_trace_contract": {
    "contract_name": "validator_raw_trace_and_severity_audit_v1",
    "core_rule": "Validator emits categorized raw trace; Audit Layer owns severity classification.",
    "validator_can_classify_final_severity": false,
    "audit_layer_owns_severity": true,
    "fail_cannot_be_silently_downgraded": true,
    "accepted_review_requires_evidence_ref": true,
    "representation_mismatch_is_not_safety_failure_by_default": true,
    "trace_categories": [
      "TRACE_TIMER",
      "TRACE_SERVICE",
      "TRACE_DB",
      "TRACE_AUTHORITY",
      "TRACE_WALLET",
      "TRACE_DATA_SOURCE",
      "TRACE_PARSER",
      "TRACE_SCHEMA",
      "TRACE_CANONICAL",
      "TRACE_QUARANTINE",
      "TRACE_ROUTE",
      "TRACE_RISK",
      "TRACE_MATRIX",
      "TRACE_PANEL",
      "TRACE_AI_CALIBRATION",
      "TRACE_SYSTEM_GATE",
      "TRACE_EMERGENCY_BRAKE"
    ],
    "raw_trace_required_fields": [
      "trace_uid",
      "trace_category",
      "trace_code",
      "trace_message",
      "trace_source",
      "source_file_or_unit",
      "observed_value",
      "expected_value",
      "context_ref",
      "evidence_ref",
      "created_at",
      "validator_version",
      "contract_version"
    ],
    "raw_trace_forbidden_fields": [
      "final_severity",
      "final_route",
      "hardblock_override",
      "paper_decision",
      "live_decision",
      "wallet_permission",
      "canonical_promotion"
    ],
    "severity_classes": {
      "PASS": {
        "rank": 0,
        "meaning": "No issue or expected clean condition.",
        "action": "continue"
      },
      "WARN": {
        "rank": 1,
        "meaning": "Non-blocking weak signal; monitor only.",
        "action": "monitor"
      },
      "REVIEW": {
        "rank": 2,
        "meaning": "Needs review; not enough evidence for FAIL.",
        "action": "review_before_promotion_or_route"
      },
      "ACCEPTED_REVIEW": {
        "rank": 3,
        "meaning": "Known false positive or representation mismatch accepted by direct evidence.",
        "action": "document_acceptance_with_evidence_ref"
      },
      "FAIL": {
        "rank": 4,
        "meaning": "Confirmed safety, integrity, authority, or runtime failure.",
        "action": "block_or_reject_according_to_gate"
      }
    },
    "classification_rules": [
      {
        "rule_id": "S001",
        "trace_category": "TRACE_AUTHORITY",
        "pattern": "paper_live_wallet_action_attempt_when_authority_closed",
        "severity": "FAIL",
        "route_effect": "AUTHORITY_BLOCK",
        "requires": [
          "direct_current_evidence"
        ],
        "notes": "Authority violation is fail."
      },
      {
        "rule_id": "S002",
        "trace_category": "TRACE_WALLET",
        "pattern": "eth_sendRawTransaction_or_private_key_or_transaction_signing",
        "severity": "FAIL",
        "route_effect": "AUTHORITY_BLOCK",
        "requires": [
          "direct_current_evidence"
        ],
        "notes": "Actual signing/sending is fail."
      },
      {
        "rule_id": "S003",
        "trace_category": "TRACE_WALLET",
        "pattern": "wallet_sign_literal_inside_negative_policy",
        "severity": "ACCEPTED_REVIEW",
        "route_effect": "NO_BLOCK",
        "requires": [
          "context_ref",
          "evidence_ref"
        ],
        "notes": "Negative policy text is not wallet action."
      },
      {
        "rule_id": "S004",
        "trace_category": "TRACE_TIMER",
        "pattern": "systemctl_show_missing_oncalendar_but_unit_has_onboot_onunitactive",
        "severity": "ACCEPTED_REVIEW",
        "route_effect": "NO_BLOCK",
        "requires": [
          "direct_unit_file_evidence"
        ],
        "notes": "Timer trigger representation mismatch accepted by direct unit evidence."
      },
      {
        "rule_id": "S005",
        "trace_category": "TRACE_SERVICE",
        "pattern": "oneshot_service_inactive_with_result_success_execmainstatus_0",
        "severity": "PASS",
        "route_effect": "NO_BLOCK",
        "requires": [
          "systemd_current_evidence"
        ],
        "notes": "Inactive oneshot after success is expected."
      },
      {
        "rule_id": "S006",
        "trace_category": "TRACE_DB",
        "pattern": "db_integrity_or_quick_check_failed",
        "severity": "FAIL",
        "route_effect": "SYSTEM_BLOCK",
        "requires": [
          "db_current_evidence"
        ],
        "notes": "DB health failure blocks."
      },
      {
        "rule_id": "S007",
        "trace_category": "TRACE_DATA_SOURCE",
        "pattern": "wrong_chain_or_wrong_pair_confirmed",
        "severity": "FAIL",
        "route_effect": "DATA_POISON_BLOCK",
        "requires": [
          "provenance_evidence",
          "confidence_high_or_confirmed"
        ],
        "notes": "Confirmed data poison blocks."
      },
      {
        "rule_id": "S008",
        "trace_category": "TRACE_DATA_SOURCE",
        "pattern": "single_weak_source_risk_claim",
        "severity": "REVIEW",
        "route_effect": "RISK_REVIEW",
        "requires": [
          "source_reliability_context"
        ],
        "notes": "Weak single source cannot become hard reject."
      },
      {
        "rule_id": "S009",
        "trace_category": "TRACE_PARSER",
        "pattern": "parser_version_missing_or_schema_unknown",
        "severity": "REVIEW",
        "route_effect": "MORE_DATA",
        "requires": [
          "parser_context"
        ],
        "notes": "Parser/schema uncertainty blocks canonical promotion."
      },
      {
        "rule_id": "S010",
        "trace_category": "TRACE_CANONICAL",
        "pattern": "canonical_silent_overwrite_attempt",
        "severity": "FAIL",
        "route_effect": "DATA_POISON_BLOCK",
        "requires": [
          "canonical_lineage_evidence"
        ],
        "notes": "Silent canonical overwrite is a hard fail."
      },
      {
        "rule_id": "S011",
        "trace_category": "TRACE_MATRIX",
        "pattern": "matrix_expired_or_hash_invalid",
        "severity": "REVIEW",
        "route_effect": "MORE_DATA_OR_OBSERVE_ONLY",
        "requires": [
          "matrix_version_evidence"
        ],
        "notes": "Expired matrix cannot drive route."
      },
      {
        "rule_id": "S012",
        "trace_category": "TRACE_EMERGENCY_BRAKE",
        "pattern": "emergency_brake_confirmed",
        "severity": "FAIL",
        "route_effect": "BRAKE_ROUTE",
        "requires": [
          "direct_current_evidence"
        ],
        "notes": "Emergency brake has highest priority."
      }
    ],
    "downgrade_guard": {
      "fail_to_review_allowed": false,
      "fail_to_accepted_review_allowed": false,
      "review_to_accepted_review_allowed_only_with_evidence_ref": true,
      "accepted_review_must_reference_direct_evidence": true,
      "accepted_review_must_preserve_original_trace": true
    },
    "trace_volume_control": {
      "rule": "Raw trace must be categorized and compact; no log flood into audit.",
      "dedupe_keys": [
        "trace_category",
        "trace_code",
        "source_file_or_unit",
        "observed_value",
        "expected_value",
        "context_ref"
      ],
      "aggregation_policy": "same_trace_code_same_context_can_be_counted_instead_of_repeated",
      "max_tail_lines_per_trace": 20
    },
    "future_implementation_boundary": {
      "live_schema_apply_now": false,
      "db_write_now": false,
      "panel_write_now": false,
      "runner_patch_now": false,
      "service_timer_change_now": false,
      "future_tempdb_dryrun_required_before_live": true,
      "future_real_requires_explicit_approval": true
    }
  },
