  "precomputed_matrix_contract": {
    "contract_name": "precomputed_route_matrix_v1",
    "core_rule": "Slow Path builds and validates the matrix; Fast Path only applies compact current matrix if gates clear and matrix is fresh.",
    "matrix_is_authority": false,
    "matrix_can_open_paper_live_wallet": false,
    "emergency_brake_override": true,
    "authority_gate_override": true,
    "priority_order": [
      "EMERGENCY_BRAKE",
      "AUTHORITY_GATE",
      "SYSTEM_GATE",
      "DATA_GATE",
      "RISK_GATE",
      "MATRIX_FRESHNESS_GATE",
      "PRECOMPUTED_ROUTE",
      "FINAL_ROUTE"
    ],
    "builder_owner": "Slow Path / System Control + Command Decision audit layer",
    "consumer_owner": "Fast Path / Command route applicator",
    "required_matrix_fields": [
      "matrix_uid",
      "matrix_version",
      "matrix_schema_version",
      "builder_version",
      "built_at",
      "valid_from",
      "valid_until",
      "max_age_seconds",
      "volatility_class",
      "source_snapshot_ref",
      "gate_contract_version",
      "data_contract_version",
      "route_rules_ref",
      "matrix_hash",
      "confidence_level",
      "fallback_route",
      "created_at"
    ],
    "fast_path_compact_fields": [
      "matrix_uid",
      "matrix_version",
      "valid_until",
      "matrix_age_class",
      "matrix_route",
      "matrix_confidence",
      "fallback_route",
      "emergency_brake_hint"
    ],
    "slow_path_builder_inputs": [
      "system_gate_state",
      "authority_gate_state",
      "data_gate_state",
      "risk_gate_state",
      "opportunity_score_state",
      "timing_score_state",
      "market_volatility_state",
      "matrix_previous_version",
      "route_outcome_memory",
      "validator_accepted_review_memory",
      "source_reliability_snapshot",
      "canonical_version_snapshot"
    ],
    "fast_path_forbidden_heavy_inputs": [
      "raw_payload_body",
      "full_news_text",
      "deep_whale_cluster",
      "large_evidence_sidecar",
      "bulk_quarantine_payload",
      "long_ai_commentary",
      "panel_render_html",
      "full_source_reliability_recompute"
    ],
    "freshness_policy": {
      "FRESH": {
        "condition": "now <= valid_until and matrix_age_seconds <= max_age_seconds",
        "effect": "apply_matrix_if_gates_ok"
      },
      "STALE": {
        "condition": "now > valid_until or matrix_age_seconds > max_age_seconds",
        "effect": "degrade_route_to_watch_more_data_or_observe_only"
      },
      "EXPIRED": {
        "condition": "matrix_missing_or_schema_mismatch_or_hash_invalid_or_valid_until_far_past",
        "effect": "MORE_DATA_OR_OBSERVE_ONLY"
      },
      "BRAKE": {
        "condition": "emergency_brake_state != none",
        "effect": "ignore_matrix_apply_brake_route"
      }
    },
    "volatility_refresh_policy": {
      "LOW": {
        "suggested_max_age_seconds": 300,
        "route_mode": "normal_observation"
      },
      "MEDIUM": {
        "suggested_max_age_seconds": 120,
        "route_mode": "shorter_matrix_life"
      },
      "HIGH": {
        "suggested_max_age_seconds": 30,
        "route_mode": "fast_expiry_more_brake_sensitive"
      },
      "EXTREME": {
        "suggested_max_age_seconds": 15,
        "route_mode": "matrix_degrades_quickly_observe_only_bias"
      }
    },
    "matrix_storage_rule": "Future matrix storage must be compact, versioned, hashable, and append/supersede, not destructive overwrite.",
    "future_implementation_boundary": {
      "live_schema_apply_now": false,
      "db_write_now": false,
      "panel_write_now": false,
      "runner_patch_now": false,
      "service_timer_change_now": false,
      "future_tempdb_dryrun_required_before_live": true,
      "future_real_requires_explicit_approval": true
    }
  },
  "route_matrix_rules": [
    {
      "rule_id": "R001",
      "priority": 1,
      "inputs": {
        "emergency_brake": "DATA_POISON_CONFIRMED"
      },
      "route": "DATA_POISON_BLOCK",
      "route_strength": "hard",
      "matrix_allowed_to_override": false,
      "reason": "Data poison must block matrix."
    },
    {
      "rule_id": "R002",
      "priority": 2,
      "inputs": {
        "emergency_brake": "CONFIRMED_HARD_RISK"
      },
      "route": "REJECT",
      "route_strength": "hard",
      "matrix_allowed_to_override": false,
      "reason": "Confirmed hard risk beats opportunity."
    },
    {
      "rule_id": "R003",
      "priority": 3,
      "inputs": {
        "authority_gate": "NO_ACTION_AUTHORITY"
      },
      "route": "OBSERVE_ONLY",
      "route_strength": "hard",
      "matrix_allowed_to_override": false,
      "reason": "Authority closed prevents action."
    },
    {
      "rule_id": "R004",
      "priority": 4,
      "inputs": {
        "system_gate": "SYSTEM_BLOCK"
      },
      "route": "SYSTEM_BLOCK",
      "route_strength": "hard",
      "matrix_allowed_to_override": false,
      "reason": "Real system failure blocks route."
    },
    {
      "rule_id": "R005",
      "priority": 5,
      "inputs": {
        "data_gate": "DATA_POISON_REVIEW"
      },
      "route": "DATA_REVIEW",
      "route_strength": "review",
      "matrix_allowed_to_override": false,
      "reason": "Potential data poisoning needs review."
    },
    {
      "rule_id": "R006",
      "priority": 6,
      "inputs": {
        "data_gate": "MORE_DATA"
      },
      "route": "MORE_DATA",
      "route_strength": "soft_block",
      "matrix_allowed_to_override": false,
      "reason": "Minimum data not met."
    },
    {
      "rule_id": "R007",
      "priority": 7,
      "inputs": {
        "risk_gate": "WEAK_SINGLE_SOURCE_RISK"
      },
      "route": "RISK_REVIEW",
      "route_strength": "review",
      "matrix_allowed_to_override": false,
      "reason": "Weak single-source risk cannot become hard reject."
    },
    {
      "rule_id": "R008",
      "priority": 8,
      "inputs": {
        "risk_gate": "CONFIRMED_REJECT"
      },
      "route": "REJECT",
      "route_strength": "hard",
      "matrix_allowed_to_override": false,
      "reason": "Confirmed risk reject."
    },
    {
      "rule_id": "R009",
      "priority": 9,
      "inputs": {
        "matrix_age_class": "EXPIRED"
      },
      "route": "MORE_DATA_OR_OBSERVE_ONLY",
      "route_strength": "degrade",
      "matrix_allowed_to_override": false,
      "reason": "Expired matrix cannot drive route."
    },
    {
      "rule_id": "R010",
      "priority": 10,
      "inputs": {
        "matrix_age_class": "STALE"
      },
      "route": "WATCH_ONLY_OR_MORE_DATA",
      "route_strength": "degrade",
      "matrix_allowed_to_override": false,
      "reason": "Stale matrix degrades route."
    },
    {
      "rule_id": "R011",
      "priority": 11,
      "inputs": {
        "all_gates": "CLEAR",
        "matrix_age_class": "FRESH",
        "opportunity": "HIGH",
        "timing": "GOOD",
        "risk": "LOW",
        "authority": "PAPER_ALLOWED_LATER"
      },
      "route": "PAPER_CANDIDATE",
      "route_strength": "candidate_only",
      "matrix_allowed_to_override": false,
      "reason": "Paper candidate only when authority later allows; no current action authority assumed."
    },
    {
      "rule_id": "R012",
      "priority": 12,
      "inputs": {
        "all_gates": "CLEAR",
        "matrix_age_class": "FRESH",
        "opportunity": "HIGH",
        "timing": "WEAK",
        "risk": "LOW"
      },
      "route": "WATCH_ONLY",
      "route_strength": "observe",
      "matrix_allowed_to_override": false,
      "reason": "Opportunity without timing stays watch."
    },
    {
      "rule_id": "R013",
      "priority": 13,
      "inputs": {
        "all_gates": "CLEAR",
        "matrix_age_class": "FRESH",
        "opportunity": "VERY_HIGH",
        "risk": "MEDIUM"
      },
      "route": "MOONSHOT_WATCH",
      "route_strength": "observe",
      "matrix_allowed_to_override": false,
      "reason": "High opportunity with medium risk is watch, not blind action."
    },
    {
      "rule_id": "R014",
      "priority": 14,
      "inputs": {
        "all_gates": "CLEAR",
        "matrix_age_class": "FRESH",
        "opportunity": "LOW"
      },
      "route": "NO_ACTION",
      "route_strength": "neutral",
      "matrix_allowed_to_override": false,
      "reason": "No opportunity."
    }
  ],
  "matrix_build_lifecycle": {
    "states": [
      "DRAFT",
      "VALIDATED_IN_SLOW_PATH",
      "PUBLISHED_TO_FAST_PATH",
      "ACTIVE",
      "STALE",
      "EXPIRED",
      "SUPERSEDED",
      "REJECTED"
    ],
    "transitions": [
      {
        "from": "DRAFT",
        "to": "VALIDATED_IN_SLOW_PATH",
        "requires": [
          "route_rules_valid",
          "gate_versions_match",
          "data_contract_versions_match"
        ]
      },
      {
        "from": "VALIDATED_IN_SLOW_PATH",
        "to": "PUBLISHED_TO_FAST_PATH",
        "requires": [
          "matrix_hash_created",
          "valid_until_set",
          "fallback_route_set"
        ]
      },
      {
        "from": "PUBLISHED_TO_FAST_PATH",
        "to": "ACTIVE",
        "requires": [
          "fast_path_can_parse_compact_fields"
        ]
      },
      {
        "from": "ACTIVE",
        "to": "STALE",
        "requires": [
          "valid_until_elapsed_or_volatility_refresh_required"
        ]
      },
      {
        "from": "STALE",
        "to": "EXPIRED",
        "requires": [
          "max_age_exceeded_or_schema_mismatch_or_hash_invalid"
        ]
      },
      {
        "from": "ACTIVE",
        "to": "SUPERSEDED",
        "requires": [
          "newer_matrix_version_published"
        ]
      },
      {
        "from": "DRAFT",
        "to": "REJECTED",
        "requires": [
          "contract_validation_failed"
        ]
      }
    ],
    "rule": "Matrix lifecycle is append/supersede; no silent destructive replacement."
  },
