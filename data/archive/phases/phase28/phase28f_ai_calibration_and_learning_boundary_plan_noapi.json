      "authority": "audit_only"
    },
    {
      "domain": "validator_false_negative_memory",
      "purpose": "Find missed real failures.",
      "allowed_inputs": [
        "post_audit_failures",
        "runtime_incident_records",
        "gate_mismatch_records"
      ],
      "forbidden_inputs": [
        "unverified suspicion as truth"
      ],
      "output": "validator_tightening_suggestion",
      "authority": "audit_only"
    },
    {
      "domain": "score_weight_calibration",
      "purpose": "Suggest score weight changes based on validated outcomes.",
      "allowed_inputs": [
        "versioned_canonical",
        "route_outcomes",
        "paper_outcomes_later",
        "source_reliability_history"
      ],
      "forbidden_inputs": [
        "raw_uninterpreted",
        "quarantine_as_truth",
        "unversioned_data"
      ],
      "output": "score_weight_recommendation",
      "authority": "audit_then_future_approval"
    },
    {
      "domain": "source_reliability_learning",
      "purpose": "Track which data sources are reliable or noisy.",
      "allowed_inputs": [
        "source_ref",
        "raw_hash",
        "parser_version",
        "validation_result",
        "quarantine_outcome"
      ],
      "forbidden_inputs": [
        "source_opinion_without_outcome"
      ],
      "output": "source_reliability_suggestion",
      "authority": "audit_only"
    },
    {
      "domain": "data_drift_memory",
      "purpose": "Detect parser/schema/source drift before poisoning canonical.",
      "allowed_inputs": [
        "parser_version_history",
        "schema_version_history",
        "canonical_version_history",
        "quarantine_reasons"
      ],
      "forbidden_inputs": [
        "silent_overwrite_history"
      ],
      "output": "data_drift_alert",
      "authority": "data_gate_audit"
    },
    {
      "domain": "matrix_route_learning",
      "purpose": "Improve matrix route rules without direct Fast Path mutation.",
      "allowed_inputs": [
        "matrix_version",
        "matrix_route",
        "final_route",
        "outcome_ref",
        "gate_state_snapshot"
      ],
      "forbidden_inputs": [
        "live_inference_output_as_route"
      ],
      "output": "matrix_rule_suggestion",
      "authority": "audit_then_future_approval"
    },
    {
      "domain": "quarantine_lifecycle_learning",
      "purpose": "Reduce digital graveyard risk and recommend retry/promotion/reject paths.",
      "allowed_inputs": [
        "quarantine_reason",
        "review_state",
        "retry_result",
        "second_source_confirmation"
      ],
      "forbidden_inputs": [
        "auto_promote_without_evidence"
      ],
      "output": "quarantine_review_suggestion",
      "authority": "audit_only"
    }
  ],
