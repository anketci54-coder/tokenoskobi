  "ai_memory_domains": [
    {
      "domain": "validator_false_positive_memory",
      "purpose": "Reduce known representation-mismatch noise without hiding true failures.",
      "allowed_inputs": [
        "ACCEPTED_REVIEW with evidence_ref",
        "original_trace",
        "direct_current_evidence"
      ],
      "forbidden_inputs": [
