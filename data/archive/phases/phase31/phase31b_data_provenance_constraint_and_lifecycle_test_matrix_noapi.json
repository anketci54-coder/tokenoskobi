    "contract_name": "data_provenance_constraint_and_lifecycle_test_matrix_v1",
    "core_rule": "Stress-test RAW -> STAGING -> VALIDATED -> CANONICAL -> QUARANTINE lifecycle constraints in temp DB only; live DB schema is not changed.",
    "pipeline_order": [
      "RAW",
      "STAGING",
      "VALIDATED",
      "CANONICAL",
      "QUARANTINE"
    ],
    "lifecycle_rules": [
      "RAW must be immutable and uniquely hash-addressed.",
      "STAGING must reference RAW.",
      "VALIDATED must reference STAGING.",
      "CANONICAL must reference VALIDATED.",
      "CANONICAL is versioned and no silent overwrite is allowed.",
      "CANONICAL v2+ must supersede an existing canonical_uid.",
      "QUARANTINE is not truth and truth_flag must stay 0.",
      "Every stage requires parser_version, schema_version, raw_hash, source_hash, evidence_ref, created_utc.",
      "Invalid lifecycle status values are rejected.",
      "Foreign key breaks are rejected."
    ],
    "expected_case_count_min": 20,
