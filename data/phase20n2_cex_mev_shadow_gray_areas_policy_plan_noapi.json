  "gray_area_policy": {
    "policy_name": "CEX_MEV_SHADOW_GRAY_AREAS_POLICY_V1_PLAN",
    "phase_scope": "PLAN_ONLY_NOAPI",
    "why_now": "20M and 20N dry-runs passed, but CEX internal transfer, private orderflow/contract mimicry, and state bloat risks must be locked before 20O shadow label dry-run.",
    "core_rule": "Eksik veri clean değildir; belirsizlik suppressor veya TTL/decay konusu olur.",
    "no_decision_from_gray_area": true,
    "hard_rules": [
      "CEX internal transfer cannot be observed onchain; it must be treated as OFFCHAIN_CEX_BLIND_SPOT.",
      "CEX internal transfer risk cannot create hard merge, hard deny, clean, paper, or live signal.",
      "CEX bridge candidates must have TTL, decay, and archive policy.",
      "Stale weak bridge candidates must not remain in active readmodel.",
      "Amount splitting tolerance may create suspicion, not proof.",
      "Private orderflow / builder route suspicion suppresses investor-whale interpretation.",
      "Ephemeral contract / contract mimicry suspicion suppresses investor-whale interpretation.",
      "MEV private/builder uncertainty cannot create hard deny, clean, paper, or live signal.",
      "Archived or expired bridge evidence must stay out of critical path and hot readmodel.",
      "Gray area logic cannot run DB query, graph traversal, external call, or blocking disk write on critical path."
    ]
  },
  "gray_area_items": [
    {
      "gray_area": "OFFCHAIN_CEX_BLIND_SPOT",
      "problem": "CEX internal transfers are invisible onchain; funds may move between accounts inside exchange before withdrawal.",
      "risk": "System may miss A->CEX->internal transfer->B relationship or rely on weak time/amount correlation.",
      "policy": "Treat as blind spot, not evidence. Use only weak/medium bridge suspicion when time/amount/proximity is present.",
      "decision_allowed": false,
      "hard_merge_allowed": false,
      "hard_deny_allowed": false,
      "clean_allowed": false,
      "paper_allowed": false,
      "live_allowed": false,
      "future_field": "offchain_cex_blind_spot_flag"
    },
    {
      "gray_area": "CEX_AMOUNT_SPLITTING_TOLERANCE",
      "problem": "One inbound amount may be split into several withdrawals or several inbounds may merge into one withdrawal.",
      "risk": "Strict amount matching misses relationship; loose amount matching creates false positives.",
      "policy": "Use bounded tolerance bands and output only probabilistic bridge suspicion.",
      "decision_allowed": false,
      "hard_merge_allowed": false,
      "hard_deny_allowed": false,
      "clean_allowed": false,
      "paper_allowed": false,
      "live_allowed": false,
      "future_field": "amount_splitting_tolerance_band"
    },
    {
      "gray_area": "CEX_BRIDGE_TTL_AND_DECAY",
      "problem": "Weak bridge candidates can accumulate and bloat state.",
      "risk": "Async graph/readmodel becomes slow and noisy.",
      "policy": "Use chain/time/risk-tier based active TTL. Archive stale weak candidates.",
      "decision_allowed": false,
      "hard_merge_allowed": false,
      "hard_deny_allowed": false,
      "clean_allowed": false,
      "paper_allowed": false,
      "live_allowed": false,
      "future_field": "bridge_active_until_utc"
    },
    {
      "gray_area": "PRIVATE_ORDERFLOW_SUSPECTED",
      "problem": "Private/builder orderflow may bypass public mempool visibility.",
      "risk": "A private MEV/builder route can look like hidden whale accumulation.",
      "policy": "Suppress investor-whale interpretation when private orderflow/builder route is suspected.",
      "decision_allowed": false,
      "hard_merge_allowed": false,
      "hard_deny_allowed": false,
      "clean_allowed": false,
      "paper_allowed": false,
      "live_allowed": false,
      "future_field": "private_orderflow_suspected"
    },
    {
      "gray_area": "EPHEMERAL_CONTRACT_MIMICRY",
      "problem": "Bots may use temporary contracts or contract-like execution patterns.",
      "risk": "Advanced MEV/liquidator behavior may be misread as whale activity.",
      "policy": "Classify as contract mimicry candidate; suppress whale buy signal until proven otherwise.",
      "decision_allowed": false,
      "hard_merge_allowed": false,
      "hard_deny_allowed": false,
      "clean_allowed": false,
      "paper_allowed": false,
      "live_allowed": false,
      "future_field": "ephemeral_contract_mimicry_flag"
    },
    {
      "gray_area": "STATE_BLOAT_GUARD",
      "problem": "Probabilistic bridge and shadow candidates can grow without bound.",
      "risk": "Readmodel and async path slow down over time.",
      "policy": "Limit active candidate count per wallet/entity/source; archive low-value candidates.",
      "decision_allowed": false,
      "hard_merge_allowed": false,
      "hard_deny_allowed": false,
      "clean_allowed": false,
      "paper_allowed": false,
      "live_allowed": false,
      "future_field": "active_candidate_budget_key"
    }
  ],
  "ttl_decay_policy": [
