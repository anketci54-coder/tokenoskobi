  </div>
</section>
<script id="coinoskobi-risk-security-active-script-v1">
(function(){
  const root = document.getElementById('coinoskobi-risk-security-active-content-v1');
  if(!root) return;
  const esc = (v) => String(v === null || v === undefined ? '' : v)
    .replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'","&#039;");
  const centerTitle = {risk:'Risk & Güvenlik Merkezi',komuta:'Komuta Merkezi',yasam:'Yaşam Destek Merkezi',sistem:'Sistem Kontrol Merkezi'};
  const cardHtml = (card) => {
    const plan = card.plan || null;
    let kv = '';
    if(plan && typeof plan === 'object') {
      const fields = [
        ['Mod', plan.entry_mode], ['Sembol', plan.symbol], ['Risk', plan.risk_level], ['MEV', plan.mev_gate],
        ['Miktar', plan.entry_amount_usd], ['Entry', plan.entry_level], ['Slipaj', plan.dynamic_slippage_pct],
        ['TP', plan.tp_policy], ['SL', plan.sl_price], ['Tek TP', plan.single_tp_price],
        ['TP1', plan.tp1_price], ['TP2', plan.tp2_price], ['TP3', plan.tp3_price]
      ].filter(x => x[1] !== null && x[1] !== undefined);
      kv = '<div class="rs-kv">' + fields.map(x => '<div><b>'+esc(x[0])+'</b><span>'+esc(x[1])+'</span></div>').join('') + '</div>';
    } else if(card.buttons && typeof card.buttons === 'object') {
      kv = '<div class="rs-kv">' + Object.entries(card.buttons).map(x => '<div><b>'+esc(x[0])+'</b><span>'+esc(x[1])+'</span></div>').join('') + '</div>';
    }
    return '<article class="rs-card">'
      + '<div class="rs-card-top"><h4>'+esc(card.title || card.card_key)+'</h4><span class="status">'+esc(card.status || '')+'</span></div>'
      + (card.value !== undefined && card.value !== null ? '<div class="value">'+esc(card.value)+'</div>' : '')
      + '<p>'+esc(card.details || card.rule || '')+'</p>'
      + kv
      + '</article>';
  };
  fetch('data/risk_security_preview_data.json?v=20260522_164904', {cache:'no-store'})
    .then(r => r.json())
    .then(data => {
      const cards = data.card_by_key || Object.fromEntries((data.cards || []).map(c => [c.card_key, c]));
      const html = (data.panel_slots || []).map(slot => {
        const slotCards = (slot.cards || []).map(k => cards[k]).filter(Boolean).map(cardHtml).join('');
        return '<section class="rs-slot">'
          + '<div class="rs-slot-head"><div><small>'+esc(centerTitle[slot.center_key] || slot.center_key)+'</small><h3>'+esc(slot.sub_panel)+'</h3></div><span class="rs-slot-code">'+esc(slot.slot_key)+'</span></div>'
          + '<p class="rs-purpose">'+esc(slot.purpose || '')+'</p>'
          + '<div class="rs-cards">'+slotCards+'</div>'
          + '</section>';
      }).join('');
      root.innerHTML = html || 'Risk güvenlik kartı bulunamadı.';
    })
    .catch(err => {
      root.innerHTML = '<div class="rs-card"><h4>Risk Security yüklenemedi</h4><p>'+esc(err.message || err)+'</p></div>';
    });
})();
</script>
