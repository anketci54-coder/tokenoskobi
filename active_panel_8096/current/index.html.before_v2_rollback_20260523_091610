<section id="coinoskobi-risk-security-active-v1" data-center-mount="risk-security-komuta-yasam-sistem" data-no-9th-center="true">
  <div class="rs-shell">
    <div class="rs-head">
      <div>
        <h2>Risk & Güvenlik + Execution</h2>
        <p>Risk, Komuta, Yaşam Destek ve Sistem Kontrol altına monte edildi. Live/auto kilitli.</p>
      </div>
