<!doctype html>
<html lang="tr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Coinoskobi Production V2 Control Center</title>
<style>
/* PANEL_PRODUCTION_V2_CONTROL_CENTER_REFERENCE_V1_BEGIN */
:root{
  --bg:#050A16;
  --bg2:#07111F;
  --panel:#081427;
  --card:#0B1730;
  --card2:#101F3A;
  --active:#12385A;
  --line:#1E3A5F;
  --line2:rgba(125,211,252,.16);
  --cyan:#38BDF8;
  --green:#22C55E;
  --yellow:#FACC15;
  --red:#EF4444;
  --text:#EAF2FF;
  --muted:#8FA3BF;
  --faint:#5F708B;
}
*{box-sizing:border-box}
html,body{margin:0;width:100%;min-height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:Inter,Manrope,Arial,sans-serif}
body{
  background:
    radial-gradient(circle at 52% 18%,rgba(56,189,248,.12),transparent 35%),
    radial-gradient(circle at 80% 82%,rgba(34,197,94,.08),transparent 36%),
    linear-gradient(135deg,#030712 0%,#050A16 44%,#07111F 100%);
}
.app{
  width:100vw;height:100vh;
  display:grid;
  grid-template-columns:280px minmax(0,1fr) 292px;
  grid-template-rows:92px minmax(0,1fr);
  overflow:hidden;
}
.sidebar{
  grid-row:1/3;
  background:linear-gradient(180deg,rgba(8,20,39,.96),rgba(3,7,18,.94));
  border-right:1px solid var(--line);
  padding:22px 18px;
  overflow:hidden;
}
.brand{display:flex;gap:12px;align-items:center;padding:0 4px 22px;border-bottom:1px solid rgba(125,211,252,.13)}
.brand-logo{width:48px;height:48px;border-radius:50%;background:radial-gradient(circle,var(--cyan),#081427 60%);display:grid;place-items:center;box-shadow:0 0 30px rgba(56,189,248,.18)}
.brand-logo img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.brand-title{font-size:22px;font-weight:900;letter-spacing:.08em}
.brand-sub{font-size:11px;color:var(--muted);font-weight:800;letter-spacing:.12em;margin-top:2px}
.nav-title{margin:18px 8px 10px;color:var(--muted);font-size:12px;letter-spacing:.12em;text-transform:uppercase}
.nav{display:grid;gap:8px}
.nav-btn{
  width:100%;height:46px;border:1px solid rgba(125,211,252,.13);
  background:linear-gradient(180deg,rgba(16,31,58,.72),rgba(8,20,39,.62));
  color:var(--text);border-radius:9px;display:grid;grid-template-columns:34px 1fr;align-items:center;
  padding:0 12px;text-align:left;cursor:pointer;transition:.15s ease;overflow:hidden;
}
.nav-btn.active{background:linear-gradient(90deg,rgba(18,56,90,.98),rgba(8,20,39,.84));border-color:var(--cyan);box-shadow:inset 0 0 0 1px rgba(56,189,248,.18),0 0 22px rgba(56,189,248,.16)}
.nav-ico{width:28px;height:28px;border-radius:8px;border:1px solid rgba(56,189,248,.25);display:grid;place-items:center;color:var(--cyan);font-weight:900}
.nav-label{font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.topbar{
  grid-column:2/4;
  height:92px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;border-bottom:1px solid var(--line);
  background:linear-gradient(180deg,rgba(5,10,22,.92),rgba(5,10,22,.60));
}
.page-title{display:flex;gap:14px;align-items:center}
.page-mark{width:34px;height:34px;border:1px solid var(--cyan);border-radius:10px;display:grid;place-items:center;color:var(--cyan)}
.page-title h1{font-size:24px;margin:0;font-weight:900}
.page-title p{margin:4px 0 0;color:var(--muted);font-size:14px}
.status-line{display:flex;align-items:center;gap:20px;color:var(--muted);font-size:13px}
.status-pill{display:flex;align-items:center;gap:7px}
.dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 14px var(--green)}
.top-actions{display:flex;gap:12px}
.action{width:48px;height:48px;border:1px solid rgba(56,189,248,.25);border-radius:50%;display:grid;place-items:center;color:var(--cyan);background:rgba(8,20,39,.62);font-size:20px}
.main{
  grid-column:2/3;
  grid-row:2/3;
  padding:22px;
  overflow:hidden;
  display:grid;
  grid-template-rows:290px minmax(0,1fr);
  gap:18px;
}
.hero{
  position:relative;
  border:1px solid var(--cyan);
  border-radius:4px;
  background:linear-gradient(180deg,rgba(8,20,39,.86),rgba(3,7,18,.82));
  box-shadow:0 0 0 1px rgba(56,189,248,.10),inset 0 0 60px rgba(56,189,248,.05);
  overflow:hidden;
}
.hero:before,.hero:after{content:"";position:absolute;inset:12px;border:1px solid rgba(56,189,248,.16);clip-path:polygon(0 10%,38% 10%,42% 0,60% 0,64% 10%,100% 10%,100% 90%,64% 90%,60% 100%,42% 100%,38% 90%,0 90%)}
.hero:after{inset:26px;opacity:.55}
.hero-inner{
  position:relative;z-index:1;height:100%;
  display:grid;grid-template-columns:1fr 320px 1fr;align-items:center;gap:22px;padding:26px 58px;
}
.health-box,.runtime-box{
  border:1px solid rgba(125,211,252,.22);border-radius:7px;background:rgba(5,10,22,.58);
  min-height:154px;display:grid;place-items:center;text-align:center;padding:18px;
}
.box-title{font-size:14px;font-weight:900;margin-bottom:14px}
.check{width:72px;height:72px;border-radius:50%;border:2px solid var(--green);display:grid;place-items:center;color:var(--green);font-size:40px;margin:auto;box-shadow:0 0 22px rgba(34,197,94,.18)}
.ok-text{margin-top:12px;color:var(--green);font-weight:900}
.small{font-size:12px;color:var(--muted);margin-top:8px}
.master-logo-wrap{
  justify-self:center;align-self:center;text-align:center;
}
/* MASTER_LOGO_TOP_CENTER_ON_DETAIL */
.master-logo{
  width:230px;height:230px;border-radius:50%;display:grid;place-items:center;margin:auto;
  background:radial-gradient(circle,rgba(56,189,248,.24),rgba(5,10,22,.8) 58%,transparent 70%);
  filter:drop-shadow(0 0 30px rgba(56,189,248,.28));
}
.master-logo img{width:100%;height:100%;object-fit:cover;border-radius:50%;transform:scale(1.03)}
.content{
  min-height:0;overflow:hidden;
  display:grid;grid-template-rows:auto minmax(0,1fr) auto;gap:14px;
}
.section-card{
  border:1px solid rgba(125,211,252,.15);border-radius:10px;background:linear-gradient(180deg,rgba(8,20,39,.82),rgba(3,7,18,.72));padding:16px;min-height:0;overflow:hidden;
}
.section-title{font-size:16px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;margin:0 0 12px}
.components{
  display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;
}
.comp{
  min-height:92px;border:1px solid rgba(56,189,248,.22);border-radius:8px;background:rgba(11,23,48,.62);
  display:grid;place-items:center;text-align:center;padding:12px;overflow:hidden;
}
.comp-ico{font-size:26px;color:var(--cyan);margin-bottom:8px}
.comp-name{font-weight:800;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.comp-status{font-size:12px;color:#86EFAC;margin-top:6px}
.module-strip{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
.module-mini{
  min-height:78px;border:1px solid rgba(192,132,252,.25);border-radius:8px;background:linear-gradient(180deg,rgba(32,13,54,.45),rgba(11,23,48,.50));
  display:grid;grid-template-columns:42px minmax(0,1fr);align-items:center;gap:10px;padding:10px;overflow:hidden;
}
.module-mini img{width:40px;height:40px;border-radius:12px;object-fit:cover}
.module-mini b{display:block;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.module-mini span{font-size:11px;color:#86EFAC}
.global-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.rightbar{
  grid-column:3/4;
  grid-row:2/3;
  padding:22px 18px 22px 0;
  display:grid;grid-template-rows:264px 1fr 244px;gap:16px;overflow:hidden;
}
.sidebox{
  border:1px solid rgba(125,211,252,.14);border-radius:9px;background:linear-gradient(180deg,rgba(8,20,39,.82),rgba(3,7,18,.72));
  padding:18px;overflow:hidden;
}
.sidebox h3{font-size:15px;margin:0 0 18px;text-transform:uppercase}
.metric{display:flex;justify-content:space-between;border-bottom:1px solid rgba(125,211,252,.10);padding:12px 4px;color:var(--muted)}
.metric strong{color:var(--text)}
.warn{color:#F59E0B!important}.err{color:var(--red)!important}
.empty-alarm{height:150px;border:1px solid rgba(125,211,252,.10);border-radius:8px;display:grid;place-items:center;color:var(--muted);text-align:center}
.quick{display:grid;gap:10px}
.quick button{height:50px;border-radius:8px;border:1px solid rgba(125,211,252,.13);background:rgba(11,23,48,.62);color:var(--text);text-align:left;padding:0 14px;font-size:14px}
@media(max-width:1100px){
  .app{grid-template-columns:230px minmax(0,1fr);grid-template-rows:82px minmax(0,1fr)}
  .rightbar{display:none}
  .topbar{grid-column:2/3}
  .hero-inner{grid-template-columns:1fr 240px 1fr;padding:22px}
  .master-logo{width:190px;height:190px}
  .components{grid-template-columns:repeat(3,minmax(0,1fr))}
}
@media(max-width:760px){
  html,body{overflow:auto}
  .app{height:auto;min-height:100vh;display:block;overflow-x:hidden}
  .sidebar{display:none}
  .topbar{height:auto;padding:16px;display:block}
  .status-line,.top-actions{display:none}
  .main{display:block;padding:14px}
  .hero{height:auto;margin-bottom:14px}
  .hero-inner{display:block;text-align:center;padding:18px}
  .health-box,.runtime-box{display:none}
  .master-logo{width:160px;height:160px}
  .components{grid-template-columns:1fr}
  .module-strip{grid-template-columns:1fr}
  .global-grid{grid-template-columns:1fr}
}
/* PANEL_PRODUCTION_V2_CONTROL_CENTER_REFERENCE_V1_END */
</style>

<style id="PANEL_PRODUCTION_V2_DENSITY_POLISH_V1">
