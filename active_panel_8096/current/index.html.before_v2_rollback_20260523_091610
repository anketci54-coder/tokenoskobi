<style id="coinoskobi-global-shell-density-patch-v1">
/* Coinoskobi active 8096 global shell density patch v1
   Purpose: compact 100% browser zoom for 1366x768 / 1536x864.
   Scope: common dashboard shell only. No DB/API/live/paper/auto behavior.
   Keeps fixed 8-center architecture.
*/

:root {
  --cx-shell-pad: clamp(6px, 0.72vw, 12px);
  --cx-shell-gap: clamp(6px, 0.62vw, 11px);
  --cx-shell-radius: clamp(9px, 0.82vw, 14px);
